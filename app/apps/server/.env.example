# =============================================================================
# f-Socials server — environment configuration
#
# Copy this file to `.env` and fill in what you have. The first slice runs with
# NONE of these set (mock providers + in-memory infra). Add each value as you
# wire the matching real provider.
#
# The PROVIDER/DRIVER selectors default to the offline mock/memory path, so the
# app keeps running until a real provider is implemented AND selected here.
# =============================================================================

# ---- core ----
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:5173      # web app origin (share links, CORS)
API_BASE_URL=http://localhost:4000

# ---- abuse control ----
RATE_LIMIT_ANON_PER_DAY=10

# ---- CORS (production only) ----
# Set to the web origin (e.g. https://app.f-socials.com) to send CORS headers.
# Leave empty in dev — the Vite proxy handles same-origin /api calls.
CORS_ORIGIN=

# =============================================================================
# PROVIDER / DRIVER SELECTORS   (leave as mock/memory until configured below)
# =============================================================================
LLM_PROVIDER=mock                # mock | gemini | openai
TRANSCRIPT_PROVIDER=passthrough  # passthrough | deepgram | youtube
EVIDENCE_PROVIDER=mock           # mock | google_factcheck | gdelt | tavily | chain
PERSPECTIVE_PROVIDER=mock        # mock | bridging  (Tavily + Gemini)
EMBEDDING_PROVIDER=mock          # mock | openai | gemini
CACHE_DRIVER=memory              # memory | upstash
QUEUE_DRIVER=memory              # memory | upstash
REPO_DRIVER=memory               # memory | postgres

# =============================================================================
# LLM — claim extraction, framing signals, issue-frame mapping
# You're running BOTH; pick per-call or set LLM_PROVIDER above.
# =============================================================================
# Google Gemini  ->  https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite      # primary model
GEMINI_MODEL_BACKUP=gemini-3-flash-preview  # tried automatically if the primary errors (503/429/timeout)

# OpenAI  ->  https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Embeddings — bridging-perspective vector match (pgvector)
# NOTE: db/migrations/001_init.sql uses vector(1536) = OpenAI text-embedding-3-small.
#       Gemini text-embedding-004 is 768 dims — if you switch, change that column.
# =============================================================================
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# =============================================================================
# Transcription / speech-to-text — Deepgram
# https://console.deepgram.com/
# =============================================================================
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# =============================================================================
# YouTube Data API v3 — reserved for official metadata (not required by the
# current watch-page title extraction). https://console.cloud.google.com/
# =============================================================================
YOUTUBE_API_KEY=

# =============================================================================
# Supadata — YouTube (and other platform) transcripts, works when YouTube blocks
# server-side caption fetch. https://supadata.ai/
# =============================================================================
SUPADATA_API_KEY=

# =============================================================================
# Article extraction — Firecrawl
# https://www.firecrawl.dev/app/api-keys
# =============================================================================
FIRECRAWL_API_KEY=

# =============================================================================
# Database — Neon Postgres (+ pgvector)
# https://console.neon.tech/  (Connection Details)
# Neon gives a pooled and a direct string:
#   DATABASE_URL          -> pooled, for the app
#   DATABASE_URL_UNPOOLED -> direct, for running migrations
# =============================================================================
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# =============================================================================
# Cache + job queue — Upstash Redis
# https://console.upstash.com/
#   REST creds  -> URL-hash cache
#   rediss URL  -> job queue (BullMQ needs the Redis-protocol URL)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# =============================================================================
# Fact-check / evidence
# EVIDENCE_PROVIDER=chain tries them in order: Google Fact Check -> Tavily.
# (single-provider values also work: google_factcheck | tavily | mock)
# =============================================================================
# Google Fact Check Tools API
# https://console.cloud.google.com/  (enable "Fact Check Tools API")
GOOGLE_FACTCHECK_API_KEY=

# Tavily search (broad retrieval for the long tail) — https://app.tavily.com/
TAVILY_API_KEY=

# =============================================================================
# News search — bridging perspectives
# PERSPECTIVE_PROVIDER=bridging uses Tavily (retrieval) + Gemini (bridging-rule
# selection). GDELT (keyless) can be added as another retrieval source later.
# https://newsapi.org/   |   GDELT: https://api.gdeltproject.org/  (no key)
# =============================================================================
NEWS_API_KEY=

# =============================================================================
# Auth — Supabase  (email + Google OAuth configured in the Supabase dashboard)
# https://supabase.com/dashboard  ->  Project Settings -> API
# =============================================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=             # server-only — never ship to the client
SUPABASE_JWT_SECRET=                   # verify auth tokens server-side

# =============================================================================
# Expert review queue — reviewer authorization
# Role (matched against the JWT `role` claim) allowed onto the review routes.
# Leave EMPTY to fail closed: an empty value denies every review route. Set to
# the reviewer role string (e.g. `reviewer`) to open the queue to those users.
# =============================================================================
REVIEWER_ROLE=

# =============================================================================
# Observability — Sentry (error monitoring) + PostHog (product analytics)
# Both are ADDITIVE and fail-open: with these unset the server + worker run
# exactly as today (Telemetry degrades to a no-op, never blocks startup or the
# pipeline). Read once in config.ts; selected in compose.ts (selectTelemetry).
# Each backend activates independently when its key is non-empty.
# =============================================================================
# Sentry  ->  https://sentry.io/  ->  Project Settings -> Client Keys (DSN)
SENTRY_DSN=

# PostHog  ->  https://app.posthog.com/  ->  Project Settings -> Project API Key
# NOTE: the server reads POSTHOG_KEY (not POSTHOG_API_KEY). The web app reads its
# own VITE_POSTHOG_KEY (+ optional VITE_POSTHOG_HOST) from apps/web's env, and is
# consent-gated (no events until the reader grants analytics consent).
POSTHOG_KEY=
