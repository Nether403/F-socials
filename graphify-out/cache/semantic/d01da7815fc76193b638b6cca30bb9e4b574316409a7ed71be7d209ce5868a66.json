{"nodes": [{"id": "lmm_fact_check_query_tuning", "label": "LLM Fact Check Query Tuning", "file_type": "document", "source_file": "LMM Fact Check query tuning.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "lmm_fact_check_query_tuning_query_pack", "label": "Query pack (multi-variant claim retrieval)", "file_type": "concept", "source_file": "LMM Fact Check query tuning.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Generate 4-8 purpose-distinct query variants per claim and separate broad recall retrieval from strict precision validation, so retrieval can be broad while only same-claim candidates become evidence."}, {"id": "lmm_fact_check_query_tuning_false_evidence_rate", "label": "False Evidence Rate (governing metric)", "file_type": "concept", "source_file": "LMM Fact Check query tuning.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The most important metric is not recall but false evidence rate \u2014 a missed citation is annoying, a wrong citation is reputational cyanide."}, {"id": "lmm_fact_check_query_tuning_evidence_outcomes", "label": "Three evidence outcomes (first-class states)", "file_type": "rationale", "source_file": "LMM Fact Check query tuning.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Matched evidence / relevant context only / no sufficient evidence are explicit backend states, keeping the lens posture and preventing the UI from implying every source verifies a claim; 'no sufficient evidence found' is a successful behavior."}], "edges": [{"source": "lmm_fact_check_query_tuning", "target": "f_socials_debt_and_todo", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "LMM Fact Check query tuning.md", "source_location": n